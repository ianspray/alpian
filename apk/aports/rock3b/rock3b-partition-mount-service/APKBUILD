pkgname=rock3b-partition-mount-service
pkgver=0.1.0
pkgrel=2
pkgdesc="ROCK3B OpenRC NVMe Partition mounter"
url="https://example.invalid/rock3b-alpian"
arch="noarch"
license="MIT"
depends="openrc busybox"
source="
  rock3b-partition-mount.sh
  rock3b-partition-mount.initd
  rock3b-partition-mount.confd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/rock3b-partition-mount.sh "$pkgdir"/usr/sbin/rock3b-partition-mount

  install -Dm755 "$srcdir"/rock3b-partition-mount.initd "$pkgdir"/etc/init.d/rock3b-partition-mount
  install -Dm644 "$srcdir"/rock3b-partition-mount.confd "$pkgdir"/etc/conf.d/rock3b-partition-mount
}


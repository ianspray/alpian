pkgname=partition-mount-service
pkgver=0.1.0
pkgrel=3
pkgdesc="Alpian OpenRC NVMe Partition mounter"
url="https://example.invalid/alpian"
arch="noarch"
license="MIT"
depends="openrc busybox"
source="
  partition-mount.sh
  partition-mount.initd
  partition-mount.confd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/partition-mount.sh "$pkgdir"/usr/sbin/partition-mount

  install -Dm755 "$srcdir"/partition-mount.initd "$pkgdir"/etc/init.d/partition-mount
  install -Dm644 "$srcdir"/partition-mount.confd "$pkgdir"/etc/conf.d/partition-mount
}


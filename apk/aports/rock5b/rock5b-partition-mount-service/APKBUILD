pkgname=rock5b-partition-mount-service
pkgver=0.1.0
pkgrel=2
pkgdesc="ROCK5B OpenRC NVMe Partition mounter"
url="https://example.invalid/rock5b-alpian"
arch="noarch"
license="MIT"
depends="openrc busybox"
source="
  rock5b-partition-mount.sh
  rock5b-partition-mount.initd
  rock5b-partition-mount.confd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/rock5b-partition-mount.sh "$pkgdir"/usr/sbin/rock5b-partition-mount

  install -Dm755 "$srcdir"/rock5b-partition-mount.initd "$pkgdir"/etc/init.d/rock5b-partition-mount
  install -Dm644 "$srcdir"/rock5b-partition-mount.confd "$pkgdir"/etc/conf.d/rock5b-partition-mount
}


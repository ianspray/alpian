BOOT_MOUNT="/boot"
ROOT_DEV=""
ROOT_MOUNT="/root"
UPDATE_MARKER="/root/.update_done"
IMAGE_PART="/dev/disk/by-label/image"
UPPER_SIZE="400M"

export PATH=/bin:/sbin:/usr/bin:/usr/sbin

mount -t proc proc /proc
mount -t sysfs sys /sys
mount -t devpts devpts /dev/pts

log() {
    echo "[init] $1"
}

fail() {
    echo "[init] ERROR: $1"
    echo "Dropping to shell"
    exec /bin/sh
}

detect_storage() {
    log "Detecting storage devices..."
    
    for dev in /dev/sd[a-z] /dev/nvme[0-9]n1 /dev/mmcblk[0-9] /dev/vda; do
        [ -b "$dev" ] && log "Found: $dev"
    done
    
    if [ -b "$IMAGE_PART" ]; then
        log "Found image partition: $IMAGE_PART"
    fi
}

check_for_update() {
    log "Checking for update image..."
    
    if [ ! -b "$IMAGE_PART" ]; then
        log "No image partition found, continuing to boot"
        return 1
    fi
    
    mount "$IMAGE_PART" /mnt 2>/dev/null
    if [ $? -ne 0 ]; then
        log "Could not mount image partition"
        return 1
    fi
    
    if [ -f "/mnt/update.img.zst" ]; then
        log "Found update image"
        
        if [ -f "/mnt/update.sha256" ]; then
            log "Verifying checksum..."
            cd /mnt
            sha256sum -c update.sha256
            if [ $? -ne 0 ]; then
                log "Checksum mismatch, aborting update"
                umount /mnt
                return 1
            fi
        fi
        
        log "Applying update..."
        zstd -d -c /mnt/update.img.zst | dd of=/dev/disk/by-label/root bs=1M status=progress
        
        if [ $? -eq 0 ]; then
            log "Update complete, marking done"
            rm -f /mnt/update.img.zst /mnt/update.sha256
            sync
            umount /mnt
            reboot -f
        else
            log "Update failed"
            umount /mnt
            return 1
        fi
    else
        log "No update image found"
        umount /mnt
        return 1
    fi
}

mount_overlayfs() {
    log "Setting up overlayfs..."
    
    mkdir -p /overlay
    mount -t tmpfs tmpfs /overlay
    mkdir -p /overlay/upper /overlay/work
    
    mkdir -p /root
    mount -o ro /dev/disk/by-label/root /root
    
    mount -t overlay overlay -o lowerdir=/root,upperdir=/overlay/upper,workdir=/overlay/work /overlay_root
    
    exec switch_root /overlay_root /sbin/init
}

init() {
    log "Alpian initramfs starting..."
    
    detect_storage
    
    check_for_update
    
    mount_overlayfs
    
    fail "Failed to switch to overlayfs"
}

init
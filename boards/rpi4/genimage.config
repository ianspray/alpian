image sdcard.img {
    vfat {
        label = "BOOT"
        filesystem = "vfat"
    }

    partition table = "gpt"

    partition boot {
        offset = 17KiB
        size = 256MiB
        label = "boot"
    }

    partition root {
        offset = 256MiB + 17KiB
        size = 1792MiB
        label = "root"
    }

    partition initramfs {
        offset = 2048MiB + 17KiB
        size = 64MiB
        label = "initramfs"
    }

    partition image {
        offset = 2112MiB + 17KiB
        size = 5880MiB
        label = "image"
    }
}
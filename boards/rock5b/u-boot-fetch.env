# Board-specific U-Boot asset fetch profile for ROCK 5B.

SPI_BASE_IMAGE_URL="${SPI_BASE_IMAGE_URL:-https://dl.radxa.com/rock5/sw/images/loader/rock-5b/release/rock-5b-spi-image-gd1cf491-20240523.img}"
SPI_BASE_IMAGE_FILENAME="${SPI_BASE_IMAGE_FILENAME:-rock-5b-spi-image-gd1cf491-20240523.img}"
SPI_IMAGE_SIZE_BYTES="${SPI_IMAGE_SIZE_BYTES:-16777216}"
SPI_IDBLOADER_LBA="${SPI_IDBLOADER_LBA:-64}"
SPI_UBOOT_ITB_LBA="${SPI_UBOOT_ITB_LBA:-16384}"
IDBLOADER_SIZE_BYTES="${IDBLOADER_SIZE_BYTES:-319488}"
UBOOT_ITB_SIZE_BYTES="${UBOOT_ITB_SIZE_BYTES:-1484288}"
